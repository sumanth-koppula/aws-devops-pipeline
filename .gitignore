# AWS DevOps Pipeline - Git Ignore Rules

# ============================================================================
# TERRAFORM SPECIFIC
# ============================================================================

# Local .terraform directories
terraform/**/.terraform/
**/.terraform/

# .tfstate files
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which might contain sensitive data
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# Ignore override files, as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan files
*.tfplan
plan.tfplan

# Ignore .terraform.lock.hcl at all levels
.terraform.lock.hcl

# ============================================================================
# AWS & CREDENTIALS
# ============================================================================

# AWS credentials and configuration
.aws/
.aws/credentials
.aws/config
aws-credentials.json

# AWS CLI output
*.awsprofile

# Private keys
*.pem
*.key
*.ppk
*.pub
id_rsa*
id_ed25519*

# ============================================================================
# NODE.JS APPLICATION
# ============================================================================

# Dependencies
app/node_modules/
node_modules/
package-lock.json
yarn.lock

# Logs
app/logs/
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime data
app/pids/
app/coverage/
.nyc_output/

# Testing
.jest/
coverage/
*.lcov

# Production build
app/dist/
app/build/
app/.next/
app/out/

# Environment variables
.env
.env.local
.env.*.local
.env.prod
.env.test

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================================================
# DOCKER
# ============================================================================

# Docker build artifacts
.docker/
docker-compose.override.yml

# Docker volumes
docker_volumes/

# ============================================================================
# ANSIBLE
# ============================================================================

# Ansible inventory files (but keep examples)
ansible/inventory/hosts.ini
!ansible/inventory/hosts.ini.example

# Ansible vault files
*.vault
ansible/.vault_pass
ansible/vault_pass.txt

# Ansible temporary files
ansible/*.retry
ansible/**/*.retry

# Ansible logs
ansible/ansible.log

# SSH keys in ansible
ansible/ssh_keys/
ansible/**/*.pem
ansible/**/*.key

# ============================================================================
# HELM
# ============================================================================

# Helm cache
.helm/
helm/*/charts/

# Generated values
helm/*/values-local.yaml
helm/values-local.yaml

# ============================================================================
# KUBERNETES & KUBECTL
# ============================================================================

# Kubernetes configuration
.kube/
kubeconfig
kubeconfig.yaml

# kubectl context files
.kubectx

# ============================================================================
# JENKINS
# ============================================================================

# Jenkins workspace
jenkins/workspace/
jenkins/jobs/
jenkins/logs/
jenkins/.jenkins/

# Jenkins pipeline logs
jenkins/**/*.log

# ============================================================================
# BUILD & COMPILATION ARTIFACTS
# ============================================================================

# Common build outputs
build/
dist/
bin/
out/
target/

# Generated files
generated/
*.generated.*

# ============================================================================
# SYSTEM FILES
# ============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Linux
.directory
.fuse_hidden*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ============================================================================
# EDITOR & IDE SPECIFIC
# ============================================================================

# VS Code
.vscode/
*.code-workspace
.vscode-test/

# IntelliJ
.idea/
*.iml
*.iws
*.ipr
.classpath
.c9/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Atom
.atom/
.atomrc

# Vim
.vim/
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
\#*\#
.\#*
.emacs.d/

# Nano
.nano_history

# ============================================================================
# VERSION CONTROL
# ============================================================================

# Git local
.git/
.gitignore_local
.gitattributes_local

# Merge/rebase artifacts
.merge_cache/
MERGE_HEAD
MERGE_MSG

# ============================================================================
# CI/CD SPECIFIC
# ============================================================================

# GitHub Actions
.github/workflows/.cache/

# Jenkins
.jenkins/
jenkins.log

# GitLab CI
.gitlab-ci.local.yml

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

# Prometheus
prometheus/data/
prometheus.db
prometheus/wal/

# Grafana
grafana/data/
grafana/plugins/

# Logs and temporary files
*.log
logs/
tmp/
temp/

# ============================================================================
# MISCELLANEOUS
# ============================================================================

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*~

# Backup files
backup/
backups/
*.tar
*.tar.gz
*.zip

# IDE scratch files
.scratch/
.tmp/

# Local configuration overrides
*-local.*
*.local.yml
*.local.yaml
*.local.json

# Secrets and sensitive data
secrets/
.secrets/
**/*-secret*
**/*secret*

# State files
*.state
state.json

# ============================================================================
# DOCUMENTATION
# ============================================================================

# Build documentation
docs/build/
docs/_build/
docs/.jekyll-cache/

# Generated API docs
api-docs/
generated-docs/

# ============================================================================
# IGNORE PATTERNS BY FILE TYPE
# ============================================================================

# Compiled binaries
*.o
*.a
*.so
*.out
*.exe

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
.pytest_cache/

# Go
*.exe
*.dll
*.so
*.dylib
/bin/
/vendor/

# ============================================================================
# LARGE FILES & BINARIES
# ============================================================================

# Database files
*.db
*.sqlite
*.sqlite3
.mongo/
mongodb/

# Cache directories
.cache/
cache/
caches/

# Virtual environments (comprehensive)
venv/
env/
ENV/
.venv/
.env/
virtualenv/

# ============================================================================
# IGNORE KEEP PATTERNS (Negation Rules)
# ============================================================================

# Keep example files
!*.example
!*.example.*
!*.template
!**/examples/**
!**/*.md

# Keep lock files that are important
!terraform.tfvars.example
!.gitignore
!.gitkeep
!Dockerfile
!docker-compose.yml

# Keep documentation
!README.md
!CONTRIBUTING.md
!CHANGELOG.md
!LICENSE

# Keep template files
!*.template.tf
!*.template.yml
!*.template.yaml
!*.template.json
