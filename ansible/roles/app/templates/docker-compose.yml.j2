# Generated by Ansible — {{ ansible_date_time.iso8601 }}
version: "3.8"

services:
  nodejs-app:
    image: "{{ ecr_registry }}/p9-devops-nodejs-app:{{ app_image_tag }}"
    container_name: "{{ app_name }}"
    restart: "{{ restart_policy }}"
    ports:
      - "{{ host_port }}:{{ app_port }}"
    environment:
      NODE_ENV:    "{{ node_env }}"
      PORT:        "{{ app_port }}"
      LOG_LEVEL:   "{{ log_level }}"
      APP_VERSION: "{{ app_image_tag }}"
      DB_HOST:     "{{ db_host     | default('localhost') }}"
      DB_PORT:     "{{ db_port     | default(5432) }}"
      DB_NAME:     "{{ db_name     | default('p9db') }}"
      DB_USER:     "{{ db_username | default('admin') }}"
      DB_PASS:     "{{ db_password | default('') }}"
      AWS_REGION:  "{{ aws_region }}"
    healthcheck:
      test:         ["CMD", "wget", "-qO-", "http://localhost:{{ app_port }}/health"]
      interval:     30s
      timeout:      5s
      retries:      3
      start_period: 10s
    logging:
      driver: json-file
      options:
        max-size: "50m"
        max-file: "3"
    deploy:
      replicas: {{ app_replicas | default(1) }}
      resources:
        limits:
          cpus:   "0.5"
          memory: 512M
        reservations:
          cpus:   "0.25"
          memory: 256M

networks:
  default:
    driver: bridge